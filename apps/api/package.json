{
  "name": "@newsletter-ai-assistant/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/scripts/run-migrations.ts",
    "db:import-json": "tsx src/scripts/import-json-to-postgres.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.4",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "openai": "^4.70.3",
    "pg": "^8.13.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.0.10",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
